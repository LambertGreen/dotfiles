#!/usr/bin/env bash
# Landing pad for tool auto-injection (aisuite, devbar, etc.)
# Machine-specific: tracked but expected to diverge
# User configuration lives in ~/.bashrc.user

# Load user configuration FIRST (for proper precedence)
[ -f ~/.bashrc.user ] && source ~/.bashrc.user

# Load machine-local overrides (machine-specific, gitignored if exists)
[ -f ~/.bashrc.local ] && source ~/.bashrc.local

# ========================================
# TOOL INJECTION ZONE
# Tools may auto-modify below this line
# ========================================

# DevBar: AI agent management tool (Salesforce internal)
# Only enable if DevBar is installed on this system
if [ -d "$HOME/.devbar" ]; then
  export NODE_EXTRA_CA_CERTS="$HOME/.devbar/certs/corporate-ca-bundle.pem"
fi

# >>> aisuite >>>
export NODE_EXTRA_CA_CERTS="/Users/lambert.green/.aisuite/conf/npm-sfdc-certs.pem"
export PATH="$PATH:/Users/lambert.green/.aisuite/bin:/Users/lambert.green/.aisuite/bin/aliases"
